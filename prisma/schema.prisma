generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  color        String   @default("#378ADD")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  records      Record[]

  @@map("accounts")
}

model Record {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId    String        @map("account_id") @db.Uuid
  label        String
  kind         RecordKind
  fixedAmount  Decimal?      @map("fixed_amount") @db.Decimal(12, 2)
  note         String        @default("")
  displayOrder Int           @default(0) @map("display_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions Transaction[]

  @@map("records")
}

model Transaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId    String   @map("record_id") @db.Uuid
  description String
  amount      Decimal  @db.Decimal(12, 2)
  txnDate     DateTime @default(dbgenerated("CURRENT_DATE")) @map("txn_date") @db.Date
  transferRef String?  @map("transfer_ref") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("transactions")
}

enum RecordKind {
  income
  expense
  pot
  transfer

  @@map("record_kind")
}
