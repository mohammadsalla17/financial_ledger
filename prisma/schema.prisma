generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  color        String   @default("#378ADD")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  records      Record[]

  @@map("accounts")
}

model Record {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId     String              @map("account_id") @db.Uuid
  label         String
  kind          RecordKind
  fixedAmount   Decimal?            @map("fixed_amount") @db.Decimal(12, 2)
  note          String              @default("")
  displayOrder  Int                 @default(0) @map("display_order")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  scheduledFrom ScheduledTransfer[] @relation("ScheduledFrom")
  scheduledTo   ScheduledTransfer[] @relation("ScheduledTo")
  transactions  Transaction[]

  @@map("records")
}

model Transaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId    String   @map("record_id") @db.Uuid
  description String
  amount      Decimal  @db.Decimal(12, 2)
  txnDate     DateTime @default(dbgenerated("CURRENT_DATE")) @map("txn_date") @db.Date
  transferRef String?  @map("transfer_ref") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  record      Record   @relation(fields: [recordId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("transactions")
}

model ScheduledTransfer {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label      String
  kind       String
  fromId     String?   @map("from_id") @db.Uuid
  toId       String    @map("to_id") @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  frequency  String
  nextRun    DateTime  @map("next_run") @db.Date
  lastRun    DateTime? @map("last_run") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  fromRecord Record?   @relation("ScheduledFrom", fields: [fromId], references: [id], onUpdate: NoAction)
  toRecord   Record    @relation("ScheduledTo", fields: [toId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("scheduled_transfers")
}

enum RecordKind {
  income
  expense
  pot
  transfer

  @@map("record_kind")
}
